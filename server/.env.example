# ────────────────────────────────────────────────────
# Server Environment Variables
# Copy this file to .env and fill in your real values
# ────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Database (Neon PostgreSQL)
# Get your connection string from https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/aprs_db?sslmode=require

# JWT Authentication
JWT_SECRET=your-jwt-secret-at-least-32-chars-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-at-least-32-chars-long
JWT_REFRESH_EXPIRES_IN=7d

# Cloudflare R2 Storage
# Get from Cloudflare dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=aprs-uploads

# Email via Resend (always free — 3,000 emails/month, no credit card)
# 1. Sign up at https://resend.com
# 2. Go to API Keys → Create Key → paste it below
# 3. Testing (sandbox): keep FROM_EMAIL=onboarding@resend.dev
#    (sandbox only delivers to your Resend signup email)
# 4. Production: verify your domain in Resend dashboard, then set:
#    FROM_EMAIL=noreply@yourdomain.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=onboarding@resend.dev

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
